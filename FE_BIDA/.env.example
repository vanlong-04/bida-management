# .env.example - Environment Configuration

# API Base URL
VITE_API_URL=http://localhost:8000/api

# App Config
VITE_APP_NAME=Quán Bida VIP
VITE_APP_TITLE=Hệ Thống Quản Lý Quán Bida
VITE_APP_DESCRIPTION=SaaS Modern Management System

# Feature Flags
VITE_ENABLE_PDF_EXPORT=true
VITE_ENABLE_EMAIL_EXPORT=false
VITE_ENABLE_DARK_MODE=false

# Pagination
VITE_ITEMS_PER_PAGE=10

# Print Settings
VITE_PRINT_LOGO=🎱 QUÁN BIDA VIP
VITE_PRINT_TAGLINE=Giải trí, thư giãn, chất lượng hàng đầu
VITE_THERMAL_WIDTH=80
VITE_THERMAL_MARGIN=5
